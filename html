<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mis Videojuegos</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/vue/3.3.4/vue.global.prod.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, sans-serif;
      background: #f0f2f5;
      color: #333;
    }

    header {
      background: #2c3e50;
      color: white;
      padding: 1rem 2rem;
      font-size: 1.4rem;
      font-weight: bold;
    }

    main { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }

    .form-box {
      background: white;
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .form-box h2 { font-size: 1rem; margin-bottom: 1rem; color: #2c3e50; }
    .form-row {
      display: flex; gap: 1rem; flex-wrap: wrap;
    }
    .form-row input, .form-row select {
      flex: 1; min-width: 150px;
      padding: .6rem .8rem;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: .95rem;
    }
    .form-row input:focus, .form-row select:focus {
      outline: none; border-color: #2c3e50;
    }
    button.agregar {
      background: #2c3e50; color: white;
      border: none; padding: .65rem 1.5rem;
      border-radius: 6px; font-size: .95rem;
      cursor: pointer;
    }
    button.agregar:hover { background: #3d5166; }
    button.agregar:disabled { background: #aaa; cursor: not-allowed; }

    .filtros {
      background: white;
      border-radius: 8px;
      padding: 1rem 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;
    }
    .filtros input, .filtros select {
      padding: .55rem .8rem;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: .9rem;
      flex: 1; min-width: 150px;
    }
    .filtros input:focus, .filtros select:focus {
      outline: none; border-color: #2c3e50;
    }
    .filtros span { font-size: .85rem; color: #888; white-space: nowrap; }

    table {
      width: 100%; border-collapse: collapse;
      background: white;
      border-radius: 8px; overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    thead { background: #2c3e50; color: white; }
    th { padding: .8rem 1rem; text-align: left; font-size: .85rem; font-weight: 600; }
    td { padding: .75rem 1rem; font-size: .9rem; border-bottom: 1px solid #eee; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8f9fa; }

    .badge {
      display: inline-block;
      padding: .25rem .6rem;
      border-radius: 4px;
      font-size: .75rem; font-weight: 600;
    }
    .badge-jugando    { background: #d4edda; color: #155724; }
    .badge-completado { background: #cce5ff; color: #004085; }
    .badge-pendiente  { background: #fff3cd; color: #856404; }
    .badge-abandonado { background: #f8d7da; color: #721c24; }

    button.eliminar {
      background: #e74c3c; color: white;
      border: none; padding: .35rem .8rem;
      border-radius: 4px; font-size: .8rem;
      cursor: pointer;
    }
    button.eliminar:hover { background: #c0392b; }

    .vacio {
      text-align: center; padding: 2rem;
      color: #888; font-size: .95rem;
    }
  </style>
</head>
<body>
<div id="app">

  <header> Mis Videojuegos</header>

  <main>

    <div class="form-box">
      <h2>Agregar juego</h2>
      <div class="form-row">
        <input v-model="form.nombre" placeholder="Nombre del juego" @keyup.enter="agregar" />
        <select v-model="form.plataforma">
          <option value="">Plataforma</option>
          <option>PS5</option>
          <option>PS4</option>
          <option>Xbox</option>
          <option>PC</option>
          <option>Switch</option>
          <option>Mobile</option>
        </select>
        <select v-model="form.estado">
          <option value="">Estado</option>
          <option>Jugando</option>
          <option>Completado</option>
          <option>Pendiente</option>
          <option>Abandonado</option>
        </select>
        <button class="agregar" @click="agregar" :disabled="!valido">Agregar</button>
      </div>
    </div>

    <div class="filtros">
      <input v-model="filtros.nombre" placeholder=" Buscar por nombre..." />
      <select v-model="filtros.plataforma">
        <option value="">Todas las plataformas</option>
        <option>PS5</option><option>PS4</option><option>Xbox</option>
        <option>PC</option><option>Switch</option><option>Mobile</option>
      </select>
      <select v-model="filtros.estado">
        <option value="">Todos los estados</option>
        <option>Jugando</option>
        <option>Completado</option>
        <option>Pendiente</option>
        <option>Abandonado</option>
      </select>
      <span>{{ juegosFiltrados.length }} resultado(s)</span>
    </div>

    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Plataforma</th>
          <th>Estado</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        <tr v-if="juegosFiltrados.length === 0">
          <td colspan="4" class="vacio">No hay juegos para mostrar.</td>
        </tr>
        <tr v-for="juego in juegosFiltrados" :key="juego.id">
          <td>{{ juego.nombre }}</td>
          <td>{{ juego.plataforma }}</td>
          <td>
            <span class="badge" :class="'badge-' + juego.estado.toLowerCase()">
              {{ juego.estado }}
            </span>
          </td>
          <td>
            <button class="eliminar" @click="eliminar(juego.id)">Eliminar</button>
          </td>
        </tr>
      </tbody>
    </table>

  </main>
</div>

<script>
const { createApp, ref, reactive, computed } = Vue;

createApp({
  setup() {
    const form = reactive({ nombre: '', plataforma: '', estado: '' });
    const filtros = reactive({ nombre: '', plataforma: '', estado: '' });

    const juegos = ref([
      { id: 1, nombre: 'Mario Bros',     plataforma: 'Switch', estado: 'Jugando'    },
      { id: 2, nombre: 'FIFA 24',        plataforma: 'PS4',    estado: 'Completado' },
      { id: 3, nombre: 'Counter Strike', plataforma: 'PC',     estado: 'Jugando'    },
      { id: 4, nombre: 'Mortal Kombat',  plataforma: 'Xbox',   estado: 'Pendiente'  },
    ]);

    let nextId = 5;

    const valido = computed(() =>
      form.nombre.trim() !== '' && form.plataforma !== '' && form.estado !== ''
    );

    const juegosFiltrados = computed(() =>
      juegos.value.filter(j =>
        j.nombre.toLowerCase().includes(filtros.nombre.toLowerCase()) &&
        (filtros.plataforma === '' || j.plataforma === filtros.plataforma) &&
        (filtros.estado === '' || j.estado === filtros.estado)
      )
    );

    function agregar() {
      if (!valido.value) return;
      juegos.value.push({
        id: nextId++,
        nombre: form.nombre.trim(),
        plataforma: form.plataforma,
        estado: form.estado,
      });
      form.nombre = ''; form.plataforma = ''; form.estado = '';
    }

    function eliminar(id) {
      if (confirm('¿Seguro que querés eliminar este juego?')) {
        juegos.value = juegos.value.filter(j => j.id !== id);
      }
    }

    return { form, filtros, juegos, juegosFiltrados, valido, agregar, eliminar };
  }
}).mount('#app');
</script>
</body>
</html>
